msgid "< Back"
msgstr "< Indietro"

msgid "<b>Fast system checks</b><br>&nbsp;&nbsp;&nbsp;System is prechecking installation environment"
msgstr "<b>Veloce controllo del sistema</b><br>&nbsp;&nbsp;&nbsp;Il sistema sta verificando preliminarmente l'ambiente di installazione"

msgid "<b>Get permissions</b><br>&nbsp;&nbsp;&nbsp;System asks for installation permissions"
msgstr "<b>Ottenimento permessi/b><br>&nbsp;&nbsp;&nbsp;Il sistema richiede permessi per installazione"

msgid "<b>Installing</b><br>&nbsp;&nbsp;&nbsp;Please wait while software is being installed"
msgstr "<b>Installazione</b><br>&nbsp;&nbsp;&nbsp;Per favore attendere mentre il software viene installato"

msgid "<b>License Agreement</b><br>&nbsp;&nbsp;&nbsp;Please review the license terms before install"
msgstr "<b>Contratto di Licenza</b><br>&nbsp;&nbsp;&nbsp;Per favore leggi il contratto di licenza prima di installare"

msgid ""
"<p><h2>Completing _SUBST_SWNAME_ setup wizard</h2><br></p>\n"
"<p>Software _SUBST_SWNAME_ has been installed on your computer.<br></p>\n"
"<p>Click Finish to close the wizard.<br><br><br><br><br></p>\n"
"<p>Visit _SUBST_SWNAME_ website for the latest news, FAQs and support</p>"
msgstr ""
"<p><h2>il programma di installazione ha completato la configurazione di _SUBST_SWNAME_</h2><br></p>\n"
"<p>Il programma _SUBST_SWNAME_ è stato installato sul tuo computer.<br></p>\n"
"<p>Clicca su \"Finish\" per chiudere lil programma di installazione<br><br><br><br><br><br></p>\n"
"<p>Visita il sito di _SUBST_SWNAME_ per le ultime novità, le domande frequenti e il supporto</p>"

msgid ""
"<p><h2>Welcome to the _SUBST_SWNAME_ setup wizard</h2></p>\n"
"<p>This wizard will guide you through the installation of the _SUBST_SWNAME_ application.</p>\n"
"<p>Click Next to continue.</p>\n"
msgstr ""
"<p><h2>Benvenuto nell'assistente di configurazione di _SUBST_SWNAME_</h2></p>\n"
"<p>Questo assistente vi guiderà nell'installazione del programma _SUBST_SWNAME_ .</p>\n"
"<p>Premi \"Avanti\" per continuare.</p>\n"

# Dati iniziali incompleti! Installazione annullata.
msgid "<p>Initial data incomplete !</p><p> Canceling installation ...</p>"
msgstr "<p>Inizializzazione dei dati incompleta !</p><p> Cancellazione dell'installazione ...</p>"

msgid "<p>Internet connection is inactive or very slow. Installer needs to download application packages from Q4OS Internet sources. Setup cannot continue ...</p>"
msgstr "<p>La connessione ad Internet non è attiva oppure è troppo lenta. L'assistente ne ha bisogno per connettersi ai server di Q4OS e scaricare i pacchetti del programma. L'installazione non può continuare ... </p>"

msgid "<p>Package system is busy, not ready to install now. Setup cannot continue.</p><p>The lock is caused, very probably, by ongoing background system updates. If this is the case, you have to wait a moment for package system to finish these operations. Please make sure you are not installing another application and repeat setup few minutes later.</p><p>Cleaning and canceling now ...</p>"
msgstr "<p>Il sistema di gestione dei pacchetti è occupato. L'installazione non può continuare.</p><p>Molto probabilmente, è in corso un aggiornamento in background oppure l'installazione di un'altra applicazione. In questo caso, basta aspettare che si concluda il processo. Per favore, prova a ripetere l'installazione tra qualche minuto.</p><p>Pulizia e annullamento dell'operazione ...</p>"

msgid "<p>Package system is in non consistent state, it has to be recovered manually. Installation cannot continue now.</p><p>Cleaning and canceling ...</p>"
msgstr "<p>Il sistema di gestione dei pacchetti non funziona correttamente, e deve essere ripristinato manualmente. L'installazione del programma non può continuare.</p><p>Pulizia e annullamento dell'operazione ...</p>"

msgid "<p>Packages couldn't be downloaded, please check your Internet connection. Sorry, I cannot install now.</p><p>Cleaning and canceling ...</p>"
msgstr "<p>Non sono riuscito a scaricare i pacchetti del programma. Per favore, controlla la tua connessione ad Internet. Mi dispiace, l'installazione non può proseguire.</p><p>Pulizia e annullamento dell'operazione ...</p>"

msgid "<p>Simulation not successful, sorry, I cannot install now.</p><p>Cleaning and canceling ...</p>"
msgstr "<p>La simulazione non è andata a buon fine. Mi dispiace, non riesco a procedere con l'installazione.</p><p>Pulizia e annullamento dell'operazione ...</p>"

msgid "<p>Warning: Canceling installation during this phase could result in package system failure.</p><p>Are you really sure, you want to interrupt the install process now ?</p>"
msgstr "<p>Attenzione: annullare l'installazione durante questa fase potrebbe causare un malfunzionamento del sistema di gestione dei pacchetti.</p><p>Sei davvero sicuro di voler interrompere il processo di installazione ora?</p>"

